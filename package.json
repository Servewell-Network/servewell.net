{
	"name": "servewellnet",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"deploy": "node scripts/pre-deploy.mjs",
		"deploy:raw": "wrangler deploy",
		"dev": "wrangler dev",
		"start": "wrangler dev",
		"test": "vitest",
		"test:run": "npm run test:unit && npm run test:inventory",
		"test:unit": "vitest --run test/index.spec.ts test/api-contracts.spec.ts",
		"test:contracts": "vitest --run test/api-contracts.spec.ts",
		"test:inventory": "vitest --run --config vitest.node.config.mts test/feature-inventory.spec.ts test/rendering-regressions.spec.ts test/rendering-global-regressions.spec.ts test/transliteration-regression.spec.ts",
		"test:api-only": "vitest --run test/index.spec.ts",
		"test:phasing": "vitest --run --config vitest.node.config.mts test/phasing.spec.ts",
		"test:e2e": "playwright test",
		"test:only-changed": "vitest --changed --run",
		"cf-typegen": "wrangler types",
		"generate:bible-spot-checks": "node scripts/generate-bible-spot-check-fixture.mjs",
		"generate:feature-inventory": "node scripts/generate-feature-inventory.mjs",
		"verify:generated": "node scripts/verify-generated-files-clean.mjs",
		"setup:hooks": "git config core.hooksPath .githooks",
		"prepare": "npm run setup:hooks",
		"pre-deploy": "node scripts/pre-deploy.mjs",
		"phasing": "tsx src/phasingScripts/phasing.ts",
		"p1a-2": "tsx src/phasingScripts/phase1aTo2.ts",
		"p1b-2": "tsx src/phasingScripts/phase1bTo2.ts",
		"p1b-review": "tsx src/phasingScripts/generateAlignmentDoubleCheck.ts",
		"p1b-apply-review": "tsx src/phasingScripts/applyAlignmentReviewSelections.ts",
		"p1b-apply-review-copy": "tsx src/phasingScripts/applyAlignmentReviewSelections.ts --review-path src/phasingScripts/phase1To2/traditional-word-alignment-double-check.txt --skip-no-row --include-unchanged-main-as-guess",
		"p2-3": "tsx src/phasingScripts/phase2To3.ts",
		"p2-words": "tsx src/phasingScripts/generateWordStudyJson.ts",
		"before-after": "node scripts/generate-before-after-report.js",
		"build:servewell-app-shell": "esbuild src/phasingScripts/phase2To3/browserEntry.ts --bundle --platform=browser --format=iife --target=es2020 --outfile=public/js/servewell-app-shell.js",
		"build:phase2to3-client": "npm run build:servewell-app-shell"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.8.19",
		"@playwright/test": "^1.59.1",
		"@types/node": "^25.5.0",
		"tsx": "^4.21.0",
		"typescript": "^5.5.2",
		"vitest": "~3.2.0",
		"wrangler": "^4.73.0"
	},
	"dependencies": {
		"wink-lemmatizer": "^3.0.4"
	}
}
