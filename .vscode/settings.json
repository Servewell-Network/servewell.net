{
	"files.associations": {
		"wrangler.json": "jsonc"
	},
	"search.useIgnoreFiles": false,
	"search.useParentIgnoreFiles": false,
	"git.repositoryScanMaxDepth": 2,
  	"git.autoRepositoryDetection": "subFolders",
	"chat.tools.terminal.autoApprove": {
		"curl -I https://servewell.net/-/Genesis/1": true,
		"/^curl -s -o /dev/null -w \"%\\{http_code\\}\" \"https://servewell\\.net/Genesis/1\" && echo \"\" && npx wrangler deploy --dry-run 2>&1 \\| head -10$/": {
			"approve": true,
			"matchCommandLine": true
		},
		"node scripts/debug-search.mjs": true,
		"npx tsx scripts/debug-search.mts": true,
		"/^npx wrangler --version 2>/dev/null \\| head -3$/": {
			"approve": true,
			"matchCommandLine": true
		},
		"/^npx wrangler deploy --dry-run 2>&1 \\| head -60$/": {
			"approve": true,
			"matchCommandLine": true
		},
		"/^npx wrangler deploy --dry-run 2>&1 \\| grep -i \"error\\\\\\|warn\\\\\\|skip\\\\\\|ignore\\\\\\|exclude\"$/": {
			"approve": true,
			"matchCommandLine": true
		},
		"/^npx wrangler deploy --dry-run 2>&1$/": {
			"approve": true,
			"matchCommandLine": true
		},
		"/^npx wrangler deploy --dry-run 2>&1 \\| grep -i \"asset\\\\\\|ignore\\\\\\|skip\\\\\\|exclude\\\\\\|found\\\\\\|-/\" \\| head -30$/": {
			"approve": true,
			"matchCommandLine": true
		},
		"/^curl -s -o /dev/null -w \"%\\{http_code\\}\" \"https://servewell\\.net/\" && echo \" \\(home\\)\" && curl -s -o /dev/null -w \"%\\{http_code\\}\" \"https://servewell\\.net/about\" && echo \" \\(about\\)\" && npx wrangler deployments list 2>&1 \\| head -20$/": {
			"approve": true,
			"matchCommandLine": true
		},
		"/^npx wrangler deployments list 2>&1 \\| grep -E \"Created:\\|Version\"$/": {
			"approve": true,
			"matchCommandLine": true
		},
		"/^npx wrangler r2 bucket cors set words-servewell-net --file scripts/r2-cors\\.json$/": {
			"approve": true,
			"matchCommandLine": true
		},
		"/^npx wrangler r2 bucket cors set servewell-words --file scripts/r2-cors\\.json$/": {
			"approve": true,
			"matchCommandLine": true
		},
		"npm run deploy:raw": false,
		"npx wrangler deploy": false,
		"npm run deploy:words-r2": false,
		"npm run deploy:trad-redirects-cf": false,
		"/^git commit .*/": false,
	}
}